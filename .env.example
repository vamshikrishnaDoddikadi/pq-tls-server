# PQ-TLS Server — Environment Variables
# Copy to .env and adjust for your deployment.

# Path to the oqs-provider shared library directory.
# Required for post-quantum key exchange (X25519MLKEM768).
OPENSSL_MODULES=/app/vendor/oqs-provider/build/lib

# Library path for vendored liboqs (needed by oqsprovider.so at runtime).
LD_LIBRARY_PATH=/app/vendor/liboqs/lib

# TLS certificate and key paths (PEM format).
# TLS_CERT=/etc/pq-tls-server/certs/server.crt
# TLS_KEY=/etc/pq-tls-server/certs/server.key

# Backend upstream address.
# BACKEND=127.0.0.1:8080

# Number of worker processes (0 = auto-detect CPU count).
# WORKERS=0

# Per-IP rate limit (connections per second, 0 = disabled).
# RATE_LIMIT=0

# Health/metrics/dashboard HTTP port (0 = disabled).
# HEALTH_PORT=9090

# Log level: debug, info, warn, error
# LOG_LEVEL=info
